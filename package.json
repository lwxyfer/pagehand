{
  "name": "pagehand",
  "displayName": "PageHand",
  "version": "0.2.0",
  "description": "A Chrome sidepanel assistant that analyzes the current page and persists AI-generated page scripts.",
  "author": "wl",
  "scripts": {
    "dev": "cross-env TARGET=chrome wxt",
    "build": "cross-env TARGET=chrome wxt build",
    "zip": "cross-env TARGET=chrome wxt zip",
    "compile": "tsc --noEmit -p tsconfig.app.json",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/node": "20.11.9",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "typescript": "5.3.3",
    "wxt": "^0.19.6"
  }
}
